# ============================================================
# MT5 Connector — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.

# --- MetaTrader 5 Terminal ---
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_LOGIN=12345678
MT5_PASSWORD=your_password_here
MT5_SERVER=YourBroker-Server
MT5_TIMEOUT=30000

# --- Symbols to track (comma-separated) ---
SYMBOLS=EURUSD,GBPUSD,USDJPY,USDCHF,AUDUSD,USDCAD,NZDUSD,EURGBP,EURJPY,GBPJPY

# --- Timeframes to store (comma-separated) ---
TIMEFRAMES=M1,M5,M15,H1,H4,D1

# --- Database (TimescaleDB / PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mt5_data
DB_USER=mt5user
DB_PASSWORD=mt5password_change_me
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Poller Settings ---
TICK_POLL_INTERVAL_MS=50
CANDLE_POLL_INTERVAL_SEC=5
BACKFILL_DAYS=30
GAP_SCAN_INTERVAL_MIN=15
MT5_HEARTBEAT_INTERVAL_SEC=10

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
WS_HEARTBEAT_SEC=30

# --- Data Retention ---
TICK_RETENTION_DAYS=90
TICK_COMPRESSION_DAYS=7
CANDLE_COMPRESSION_DAYS=30

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
